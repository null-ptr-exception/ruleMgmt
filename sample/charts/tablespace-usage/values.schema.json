{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "tablespace_usage": {
      "type": "array",
      "x-promql": "oracle_tablespace_used_percent{db_name=\"{{ .db_name }}\", tablespace_name=\"{{ .tablespace_name }}\"} > {{ THRESHOLD }}",
      "x-for": "5m",
      "items": {
        "type": "object",
        "properties": {
          "db_name": { "type": "string", "description": "Database name", "x-var-type": "selector" },
          "tablespace_name": { "type": "string", "description": "Tablespace name", "x-var-type": "selector" },
          "info": { "type": "number", "description": "Info threshold (%)", "default": 30, "x-var-type": "threshold", "x-severity": "info" },
          "warn": { "type": "number", "description": "Warning threshold (%)", "default": 50, "x-var-type": "threshold", "x-severity": "warning" },
          "critical": { "type": "number", "description": "Critical threshold (%)", "default": 70, "x-var-type": "threshold", "x-severity": "critical" },
          "severe": { "type": "number", "description": "Severe threshold (%)", "default": 95, "x-var-type": "threshold", "x-severity": "critical" }
        },
        "required": ["db_name", "tablespace_name"]
      }
    }
  }
}
