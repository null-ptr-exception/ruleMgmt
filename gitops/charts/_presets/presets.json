{
  "single-threshold-3tier": {
    "name": "Single Threshold – 3 Tier",
    "description": "Define one critical threshold; info (50%) and warn (75%) are derived automatically",
    "promqlTemplate": "METRIC_EXPR > {{ THRESHOLD }}",
    "forDuration": "5m",
    "tiers": [
      { "name": "infoThreshold",  "severity": "info",     "ratio": 0.50 },
      { "name": "warnThreshold",  "severity": "warning",  "ratio": 0.75 },
      { "name": "critThreshold",  "severity": "critical", "ratio": 1.00 }
    ],
    "vars": [
      { "name": "cluster",   "type": "string", "xVarType": "selector",        "description": "Target cluster" },
      { "name": "app",       "type": "string", "xVarType": "selector",        "description": "Target application" },
      { "name": "threshold", "type": "number", "xVarType": "threshold-base",  "default": 0.9, "description": "Critical threshold; info=50%, warn=75%, crit=100%" }
    ]
  },
  "multi-tier-threshold": {
    "name": "Multi-Tier Threshold",
    "description": "3-tier (info / warn / crit) alert for any metric comparison",
    "promqlTemplate": "METRIC_EXPR > {{ THRESHOLD }}",
    "forDuration": "5m",
    "vars": [
      { "name": "cluster",       "type": "string", "xVarType": "selector",  "description": "Target cluster" },
      { "name": "app",           "type": "string", "xVarType": "selector",  "description": "Target application" },
      { "name": "infoThreshold", "type": "number", "xVarType": "threshold", "xSeverity": "info",     "default": 0.4, "description": "Info tier threshold" },
      { "name": "warnThreshold", "type": "number", "xVarType": "threshold", "xSeverity": "warning",  "default": 0.6, "description": "Warning tier threshold" },
      { "name": "critThreshold", "type": "number", "xVarType": "threshold", "xSeverity": "critical", "default": 0.8, "description": "Critical tier threshold" }
    ]
  },
  "warn-crit-threshold": {
    "name": "Warn / Crit Threshold",
    "description": "2-tier (warn / crit) alert for any metric comparison",
    "promqlTemplate": "METRIC_EXPR > {{ THRESHOLD }}",
    "forDuration": "5m",
    "vars": [
      { "name": "cluster",       "type": "string", "xVarType": "selector",  "description": "Target cluster" },
      { "name": "app",           "type": "string", "xVarType": "selector",  "description": "Target application" },
      { "name": "warnThreshold", "type": "number", "xVarType": "threshold", "xSeverity": "warning",  "default": 0.7, "description": "Warning tier threshold" },
      { "name": "critThreshold", "type": "number", "xVarType": "threshold", "xSeverity": "critical", "default": 0.9, "description": "Critical tier threshold" }
    ]
  },
  "absence-check": {
    "name": "Absence Check",
    "description": "Service liveness — fires when metric equals 0 (e.g. up == 0)",
    "promqlTemplate": "METRIC_EXPR == 0",
    "forDuration": "3m",
    "fixedAlert": true,
    "fixedSeverity": "critical",
    "vars": [
      { "name": "cluster", "type": "string", "xVarType": "selector", "description": "Target cluster" },
      { "name": "app",     "type": "string", "xVarType": "selector", "description": "Target application" }
    ]
  }
}
