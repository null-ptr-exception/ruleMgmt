{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "kpi_cpu_saturation": {
      "type": "array",
      "x-promql": "rate(node_cpu_seconds_total{mode=\"user\"}[1m]) / scalar(count(node_cpu_seconds_total{mode=\"user\"})) > {{ THRESHOLD }}",
      "x-for": "5m",
      "items": {
        "type": "object",
        "properties": {
          "cluster": {
            "type": "string",
            "description": "Target cluster",
            "x-var-type": "selector"
          },
          "app": {
            "type": "string",
            "description": "Target application",
            "x-var-type": "selector"
          },
          "infoThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "info",
            "x-ratio": 0.5,
            "description": "info threshold (50% of base)"
          },
          "warnThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "warning",
            "x-ratio": 0.75,
            "description": "warning threshold (75% of base)"
          },
          "critThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "critical",
            "x-ratio": 1,
            "description": "critical threshold (100% of base)"
          }
        },
        "required": [
          "cluster",
          "app"
        ]
      }
    },
    "kpi_mem_saturation": {
      "type": "array",
      "x-promql": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) > {{ THRESHOLD }}",
      "x-for": "5m",
      "items": {
        "type": "object",
        "properties": {
          "cluster": {
            "type": "string",
            "description": "Target cluster",
            "x-var-type": "selector"
          },
          "app": {
            "type": "string",
            "description": "Target application",
            "x-var-type": "selector"
          },
          "infoThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "info",
            "x-ratio": 0.5,
            "description": "info threshold (50% of base)"
          },
          "warnThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "warning",
            "x-ratio": 0.75,
            "description": "warning threshold (75% of base)"
          },
          "critThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "critical",
            "x-ratio": 1,
            "description": "critical threshold (100% of base)"
          }
        },
        "required": [
          "cluster",
          "app"
        ]
      }
    },
    "kpi_disk_saturation": {
      "type": "array",
      "x-promql": "1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|devtmpfs\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|devtmpfs\"}) > {{ THRESHOLD }}",
      "x-for": "5m",
      "items": {
        "type": "object",
        "properties": {
          "cluster": {
            "type": "string",
            "description": "Target cluster",
            "x-var-type": "selector"
          },
          "app": {
            "type": "string",
            "description": "Target application",
            "x-var-type": "selector"
          },
          "infoThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "info",
            "x-ratio": 0.5,
            "description": "info threshold (50% of base)"
          },
          "warnThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "warning",
            "x-ratio": 0.75,
            "description": "warning threshold (75% of base)"
          },
          "critThreshold": {
            "type": "number",
            "x-var-type": "threshold",
            "x-severity": "critical",
            "x-ratio": 1,
            "description": "critical threshold (100% of base)"
          }
        },
        "required": [
          "cluster",
          "app"
        ]
      }
    },
    "svc_isalive": {
      "type": "array",
      "x-promql": "up == 0",
      "x-for": "3m",
      "items": {
        "type": "object",
        "properties": {
          "cluster": {
            "type": "string",
            "description": "Target cluster",
            "x-var-type": "selector"
          },
          "app": {
            "type": "string",
            "description": "Target application",
            "x-var-type": "selector"
          }
        },
        "required": [
          "cluster",
          "app"
        ]
      },
      "x-custom-template": true,
      "x-fixed-alert": true,
      "x-fixed-severity": "critical"
    }
  }
}